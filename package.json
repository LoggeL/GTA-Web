{
  "name": "heatline-solara",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HEATLINE: SOLARA — an original browser-based open-world crime-action RPG.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run release:check && tsc -p tsconfig.json && vite build && npm run release:check:dist",
    "preview": "vite preview --host 0.0.0.0",
    "preview:e2e": "npm run build && vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run && npm run test:release",
    "test:release": "node --test tests/release/release-metadata.test.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --workers=2 --project=chromium-desktop --project=chromium-mobile-landscape",
    "test:e2e:release": "playwright test e2e/desktop-smoke.spec.ts e2e/mobile-smoke.spec.ts",
    "test:performance": "HEATLINE_PERFORMANCE=1 HEATLINE_SOAK_SECONDS=30 playwright test --workers=1 --grep \"runtime frame\"",
    "test:context-recovery": "HEATLINE_PERFORMANCE=1 playwright test --grep \"WebGL context\"",
    "test:soak": "HEATLINE_PERFORMANCE=1 HEATLINE_SOAK_SECONDS=1200 playwright test --workers=1 --grep \"runtime frame\"",
    "budget": "node scripts/check-bundle.mjs",
    "release:check": "node scripts/check-release-assets.mjs",
    "release:check:dist": "node scripts/check-release-assets.mjs --dist",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build && npm run budget",
    "deploy": "npm run build"
  },
  "dependencies": {
    "three": "0.180.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.1",
    "@types/three": "0.180.0",
    "eslint": "9.39.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  }
}
