{
  "name": "heatline-solara",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HEATLINE: SOLARA — an original browser-based open-world crime-action RPG.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "budget": "node scripts/check-bundle.mjs",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build && npm run budget",
    "deploy": "npm run build"
  },
  "dependencies": {
    "three": "0.180.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.1",
    "@types/three": "0.180.0",
    "eslint": "9.39.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  }
}
